{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Gaffer staffing catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "vocabulary", "defaults", "presets", "aliases"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "const": 2 },
    "vocabulary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["taskGrades", "semanticTiers", "deliberations", "topologies", "postures", "capabilities"],
      "properties": {
        "taskGrades": { "$ref": "#/$defs/uniqueStrings" },
        "semanticTiers": { "$ref": "#/$defs/uniqueStrings" },
        "deliberations": { "$ref": "#/$defs/uniqueStrings" },
        "topologies": { "$ref": "#/$defs/uniqueStrings" },
        "postures": { "$ref": "#/$defs/uniqueStrings" },
        "capabilities": { "$ref": "#/$defs/capabilities" }
      }
    },
    "defaults": {
      "type": "object", "additionalProperties": false,
      "required": ["taskGrade", "tier", "deliberation", "topology", "posture"],
      "properties": {
        "taskGrade": { "type": "string" }, "tier": { "type": "string" }, "deliberation": { "type": "string" },
        "topology": { "type": "string" }, "posture": { "type": "string" }
      }
    },
    "presets": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/preset" } },
    "aliases": { "type": "array", "items": { "$ref": "#/$defs/alias" } }
  },
  "$defs": {
    "uniqueStrings": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "capabilities": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "enum": ["filesystem.read", "filesystem.search", "filesystem.write", "shell", "shell.readonly", "web", "coordination", "fram.graph.edit"] }
    },
    "preset": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "taskGrade", "tier", "deliberation", "topology", "posture", "capabilities", "tagline", "description"],
      "properties": {
        "name": { "$ref": "#/$defs/roleId" }, "taskGrade": { "type": "string" }, "tier": { "type": "string" },
        "deliberation": { "type": "string" }, "topology": { "type": "string" }, "posture": { "type": "string" },
        "capabilities": { "$ref": "#/$defs/capabilities" }, "tagline": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "alias": {
      "type": "object", "additionalProperties": false, "required": ["name", "target"],
      "properties": { "name": { "$ref": "#/$defs/roleId" }, "target": { "$ref": "#/$defs/roleId" } }
    },
    "roleId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
      "not": { "enum": ["researcher"] }
    }
  }
}
